{
  "manifest_version": 3,
  "name": "CatchUp",
  "version": "0.1.0",
  "description": "Spoiler-safe Q&A for streaming video. Ask what you missed — answers use only what has happened up to your current timestamp.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "minimum_chrome_version": "111",
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*", "*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["page-youtube.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["page-netflix.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CatchUp — ask about what you're watching"
  },
  "options_page": "options.html"
}
