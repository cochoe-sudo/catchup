{
  "manifest_version": 3,
  "name": "CatchUp",
  "version": "0.2.0",
  "description": "Spoiler-safe Q&A for streaming video. Ask what you missed — answers use only what has happened up to your current timestamp.",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["page-youtube.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["page-netflix.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://*.youtube.com/*", "*://*.netflix.com/*"],
      "js": ["page-texttracks.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "CatchUp — toggle the sidebar"
  },
  "options_page": "options.html"
}
